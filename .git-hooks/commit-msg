#!/bin/bash

# ============================================================================
# Git Commit Message Validator (commit-msg hook)
# ============================================================================
#
# Purpose: Validates commit messages against Conventional Commits format
# Usage:   Invoked automatically by Git as commit-msg hook
#
# IMPORTANT: This file must be executable!
#            Run: chmod +x .git/hooks/commit-msg
#
# ============================================================================

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print error messages
printError() {
    echo -e "${RED}[COMMIT REJECTED]${NC} $1"
}

# Function to print success messages
printSuccess() {
    echo -e "${GREEN}[COMMIT ACCEPTED]${NC} $1"
}

# Function to print warnings
printWarning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

# Step 1: Read commit message from the file provided by Git
COMMIT_MSG_FILE="$1"
if [ -z "$COMMIT_MSG_FILE" ] || [ ! -f "$COMMIT_MSG_FILE" ]; then
    printError "Commit message file not found!"
    exit 1
fi
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Step 2: Extract the first line of the commit message
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n 1)
FIRST_LINE_LENGTH=${#FIRST_LINE}

# Step 3: Bypass validation for merge, revert and squash commits
if echo "$FIRST_LINE" | grep -qE "^Merge "; then
    printSuccess "Bypass: merge commit detected."
    exit 0
fi

if echo "$FIRST_LINE" | grep -qE "^Revert "; then
    printSuccess "Bypass: revert commit detected."
    exit 0
fi

if echo "$FIRST_LINE" | grep -qE "^Squash "; then
    printSuccess "Bypass: squash commit detected."
    exit 0
fi

# Step 4: Define conventional commit types
VALID_TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|security|deps"

# Step 5: Define the regex pattern for conventional commits
# Format: type(scope)!: description
# - type: Required (feat, fix, docs, etc.)
# - scope: Optional, wrapped in parentheses: (api), (ui), (core)
# - !: Optional breaking change indicator
# - description: Required, must start with space
CONVENTIONAL_COMMIT_REGEX="^($VALID_TYPES)(\(.+\))?!?: .+"

# Step 6: Check if message is empty
if [ -z "$FIRST_LINE" ]; then
    printError "Commit message cannot be empty!"
    exit 1
fi

# Step 7: Check if first line follows conventional commit format
if ! echo "$FIRST_LINE" | grep -qE "$CONVENTIONAL_COMMIT_REGEX"; then
    printError "Commit message does not follow Conventional Commits format!"
    echo "Expected format: <type>(optional-scope): <description>"
    echo "Valid types: $VALID_TYPES"
    echo "Examples:"
    echo "  feat(auth): add login functionality"
    echo "  fix: resolve null pointer exception"
    echo "  docs(readme): update installation instructions"
    exit 1
fi

# Step 8: Check first line length (recommended: 50 chars, max: 72 chars)
if [ "$FIRST_LINE_LENGTH" -gt 72 ]; then
    printError "First line is too long: ${FIRST_LINE_LENGTH} characters (max: 72)"
    exit 1
elif [ "$FIRST_LINE_LENGTH" -gt 50 ]; then
    printWarning "Commit subject is ${FIRST_LINE_LENGTH} chars (recommended ≤50, max 72)"
fi

# Step 9: Check if description starts with lowercase (conventional commits best practice)
if echo "$FIRST_LINE" | grep -qE "^($VALID_TYPES)(\(.+\))?: [A-Z]"; then
    printWarning "Description should start with lowercase letter"
fi

# Step 10: Check if first line ends with a period
# Enforce Git commit style: commit subject cannot end with a period
if echo "$FIRST_LINE" | grep -qE "\.$"; then
    printError "First line should not end with a period"
    exit 1
fi

# Step 11: If there's a body, check for blank line separation
LINE_COUNT=$(echo "$COMMIT_MSG" | wc -l)
if [ "$LINE_COUNT" -gt 1 ]; then
    SECOND_LINE=$(echo "$COMMIT_MSG" | sed -n '2p')
    if [ -n "$SECOND_LINE" ]; then
        printWarning "Second line should be blank (separate subject from body)"
    fi
fi

exit 0
